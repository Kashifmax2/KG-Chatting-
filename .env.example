# KG Chatting — environment variables
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must never be committed.
#
# Note: Firebase web keys are public identifiers by design — they are safe to
# ship in the client bundle. Real protection comes from the security rules
# (firestore.rules, database.rules.json, storage.rules), not from hiding these.

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# --- Cloudinary (unsigned uploads via native fetch) ---
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
